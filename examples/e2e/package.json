{
  "name": "wilco-e2e-tests",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:dev": "WILCO_E2E_MODE=dev playwright test",
    "test:prod": "WILCO_E2E_MODE=prod playwright test",
    "test:django-unfold": "WILCO_E2E_FRAMEWORK=django-unfold playwright test --project=django-unfold-dev --project=django-unfold-prod",
    "test:django-unfold:dev": "WILCO_E2E_MODE=dev WILCO_E2E_FRAMEWORK=django-unfold playwright test --project=django-unfold-dev",
    "test:django-unfold:prod": "WILCO_E2E_MODE=prod WILCO_E2E_FRAMEWORK=django-unfold playwright test --project=django-unfold-prod",
    "test:django-vanilla": "WILCO_E2E_FRAMEWORK=django-vanilla playwright test --project=django-vanilla-dev --project=django-vanilla-prod",
    "test:django-vanilla:dev": "WILCO_E2E_MODE=dev WILCO_E2E_FRAMEWORK=django-vanilla playwright test --project=django-vanilla-dev",
    "test:django-vanilla:prod": "WILCO_E2E_MODE=prod WILCO_E2E_FRAMEWORK=django-vanilla playwright test --project=django-vanilla-prod",
    "test:flask": "WILCO_E2E_FRAMEWORK=flask playwright test --project=flask-dev --project=flask-prod",
    "test:flask:dev": "WILCO_E2E_MODE=dev WILCO_E2E_FRAMEWORK=flask playwright test --project=flask-dev",
    "test:flask:prod": "WILCO_E2E_MODE=prod WILCO_E2E_FRAMEWORK=flask playwright test --project=flask-prod",
    "test:fastapi": "WILCO_E2E_FRAMEWORK=fastapi playwright test --project=fastapi-dev --project=fastapi-prod",
    "test:fastapi:dev": "WILCO_E2E_MODE=dev WILCO_E2E_FRAMEWORK=fastapi playwright test --project=fastapi-dev",
    "test:fastapi:prod": "WILCO_E2E_MODE=prod WILCO_E2E_FRAMEWORK=fastapi playwright test --project=fastapi-prod",
    "test:starlette": "WILCO_E2E_FRAMEWORK=starlette playwright test --project=starlette-dev --project=starlette-prod",
    "test:starlette:dev": "WILCO_E2E_MODE=dev WILCO_E2E_FRAMEWORK=starlette playwright test --project=starlette-dev",
    "test:starlette:prod": "WILCO_E2E_MODE=prod WILCO_E2E_FRAMEWORK=starlette playwright test --project=starlette-prod",
    "test:asgi-minimal": "WILCO_E2E_FRAMEWORK=asgi-minimal playwright test --project=asgi-minimal-dev --project=asgi-minimal-prod",
    "test:asgi-minimal:dev": "WILCO_E2E_MODE=dev WILCO_E2E_FRAMEWORK=asgi-minimal playwright test --project=asgi-minimal-dev",
    "test:asgi-minimal:prod": "WILCO_E2E_MODE=prod WILCO_E2E_FRAMEWORK=asgi-minimal playwright test --project=asgi-minimal-prod",
    "test:wsgi-minimal": "WILCO_E2E_FRAMEWORK=wsgi-minimal playwright test --project=wsgi-minimal-dev --project=wsgi-minimal-prod",
    "test:wsgi-minimal:dev": "WILCO_E2E_MODE=dev WILCO_E2E_FRAMEWORK=wsgi-minimal playwright test --project=wsgi-minimal-dev",
    "test:wsgi-minimal:prod": "WILCO_E2E_MODE=prod WILCO_E2E_FRAMEWORK=wsgi-minimal playwright test --project=wsgi-minimal-prod",
    "test:headed": "playwright test --headed",
    "test:debug": "PWDEBUG=1 playwright test",
    "test:ui": "playwright test --ui",
    "install-browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.14.0",
    "typescript": "^5.9.0"
  }
}
